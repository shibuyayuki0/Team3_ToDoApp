@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<!-- ヘッダー追加部品 -->
@section AdditionalHeader{
    <div class="container">
        <!-- タイトル -->
        <div class="row align-items-center">
            <!-- 作成ボタン -->
            <div class="col-2 text-center">
                <a href="#" class="btn btn-primary">作成</a>
            </div>
            <div class="col-5">タスク名</div>
            <div class="col">締切日</div>
            <!-- フィルタリスト -->
            <div class="d-flex justify-content-end">
                <form method="get" asp-page-handler="Filtering" class="input-group w-auto">
                    <span class="input-group-text">
                        フィルター：</span>
                    <select name="filterName" class="form-select" onchange="this.form.submit()">

                        <option value="Continue">未完了</option>
                        <option value="Complete">完了</option>
                        <option value="All">すべて</option>

                    </select>
                </form>
            </div>
        </div>
    </div>
}

<!-- Style -->
@section Styles {
    <style>
        .return-button {
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s, visibility 0.3s;

            &.active {
                opacity: 1;
                visibility: visible;
            }
        }

        .overlay{
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: rgba(0, 0, 0, 0.6);
            z-index: 2000;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.4s ease;

            &.active {
                opacity: 1;
                visibility: visible;
            }
        }

        .detail-menu {
            position: fixed;
            top: 0;
            right: 0;
            width: 35vw;
            height: 100vh;
            z-index: 3000;
            background-color: #ffffff;
            box-shadow: -2px 0 8px rgba(0, 0, 0, 0.15);
            padding: 20px;
            box-sizing: border-box;
            overflow-y: auto;

            visibility: hidden;
            transform: translateX(100%);

            transition: transform 0.3s ease, visibility 0.3s;

            &.active {
                visibility: visible;
                animation: slideInRight 0.3s forwards ease-out;
            }
        }

        .Priority-1{
            background-color: red;
        }
        .priority-2 {
            background-color: orange;
        }

        .priority-3 {
            background-color: royalblue;
        }

        @@keyframes slideInRight {
            from {
                transform: translateX(100%);
            }

            to {
                transform: translateX(0);
            }
        }

    </style>
}


