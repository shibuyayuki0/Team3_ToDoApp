<!-- 本体 -->
<div class="container">
    <!-- タスクリスト本体 -->
    <div class="row">
        @foreach (var item in Model.ItemList)
        {
            <!-- タスク1件 -->
            <div class="col-12 d-flex gap-3">
                <!-- 警告表示 -->
                <div class="">
                    <span style="font-size:3rem;">&#x26A0;&#xFE0F;</span>
                </div>
                <!-- タスク本体 -->
                <div data-id="@item.id" class="flex-fill border rounded-3 p-4 mb-3 bg-primary-subtle text-primary-emphasis border-secondary-subtle">
                    <div class="container align-items-center">
                        <div class="row">
                            <form method="post" asp-page-handler="Complete" class="col-1">
                                <input type="hidden" name="IsCompleted" value="false" />

                                <input type="checkbox"
                                       name="IsCompleted"
                                       value="true"
                                       class="form-check-input"
                                       onchange="this.form.submit()" />
                            </form>
                            <div class="col">@item.name</div>
                            <div class="col">@Model.DeadlineAt</div>
                        </div>
                    </div>
                </div>

            </div>
        }
    </div>    
</div>

<!-- 暗転オブジェクト -->
<div id="overlay" class="overlay"></div>

<!-- 右表示メニュー -->
<div id="detail-menu" class="detail-menu">


    <div id="priority-text"></div>
    <div id="taskName"></div>
    <div id="deadLine_at"></div>
    <div id="content_text"></div>
    <div id="target-id"></div>
    <div></div>

    <div style="display:flex; gap:8px;" class="col-2 text-center">
        <a href="#" class="btn btn-primary">編集</a>
        <div></div>
        <form method="post" asp-page-handler="Delete">
            <input type="hidden" name="SelectedId" value="@Model.SelectedId" />
            <button type="submit" class="btn btn-danger">削除</button>
        </form>
    </div>


</div>

<!-- フロートボタン -->
<div id="return-button" class="return-button position-fixed" style="left:30px; bottom:15px; z-index: 1050;">
    <div class="">
        <button id="scroll-to-top" class="btn btn-primary">TOPに戻る</button>
    </div>
</div>

