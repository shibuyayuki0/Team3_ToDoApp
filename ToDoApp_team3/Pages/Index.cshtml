@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<!-- Style -->
@section Styles {
    <style>
        .completed-task {
            background-color: var(--bs-tertiary-color);
            color: var(--bs-secondary-color);
            border: 2px solid var(--bs-border-color);
        }

        .priority-1 {
            background-color: var(--bs-danger-bg-subtle);
            color: var(--bs-danger-text-emphasis);
            border: 2px solid var(--bs-danger-border-subtle);


        }

        .priority-2 {
            background-color: var(--bs-warning-bg-subtle);
            color: var(--bs-warning-text-emphasis);
            border: 2px solid var(--bs-warning-border-subtle);
        }

        .priority-3 {
            background-color: var( --bs-success-bg-subtle);
            color: var(--bs-success-text-emphasis);
            border: 2px solid var(--bs-success-border-subtle);
        }

        .custom-strike {
            &::before {
                content: "";
                position: absolute;
                top: 50%;
                left: 70px;
                right: 0;
                height: 0;
                border-top: 2px solid var(--bs-tertiary-color);
                transform: translateY(-3.5rem);
            }
        }

        @@media(min-width:576px) {
            .custom-strike::before {
                left: 75px;
            }
        }

        @@media(min-width:768px) {
            .custom-strike::before {
                left: 50px;
            }
        }

        @@media(min-width:992px) {
            .custom-strike::before {
                left: 70px;
            }
        }

        @@media(min-width:1200px) {
            .custom-strike::before {
                left: 85px;
            }
        }

        @@media(min-width:1400px) {
            .custom-strike::before {
                left: 100px;
            }
        }

        .return-button {
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s, visibility 0.3s;

            &.active {
                opacity: 1;
                visibility: visible;
            }
        }

        .overlay{
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: rgba(0, 0, 0, 0.6);
            z-index: 2000;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.4s ease;

            &.active {
                opacity: 1;
                visibility: visible;
            }
        }

        .btn-complete{
            width: 2rem;
            height: 2rem;
        }

        .detail-menu {
            position: fixed;
            top: 0;
            right: 0;
            width: 35vw;
            height: 100vh;
            z-index: 3000;
            background-color: #ffffff;
            box-shadow: -2px 0 8px rgba(0, 0, 0, 0.15);
            padding: 20px;
            box-sizing: border-box;
            overflow-y: auto;

            visibility: hidden;
            transform: translateX(100%);

            transition: transform 0.3s ease, visibility 0.3s;

            &.active {
                visibility: visible;
                animation: slideInRight 0.3s forwards ease-out;
            }
        }

        @@keyframes slideInRight {
            from {
                transform: translateX(100%);
            }

            to {
                transform: translateX(0);
            }
        }

    </style>
}


<!-- JavaScript -->
@section Scripts {
    <script>
        const overlay = document.getElementById("overlay");
        const detailMenu = document.getElementById("detail-menu");


        
        const taskName = document.getElementById("taskName");
        const priorityId = document.getElementById("priorityId");
        const deadlineAt = document.getElementById("deadlineAt");
        const contentText = document.getElementById("contentText");


        let targetTaskId; // 削除や編集を行う対象タスク

        // 1.クリック時の処理
        document.addEventListener("click", (e) => {
            // リンク先情報をクリア
            targetTaskId = "";
            
            // click-withoutだった時はスキップ
            if (e.target.closest('[click-without]')) {
                return;
            }

            // [data-id]属性をもっていれば処理
            const targetTask = e.target.closest('[data-id]');
            if (targetTask){
                targetTaskId = targetTask.getAttribute("data-id");



                overlay.classList.add("active"); // 暗転
                detailMenu.classList.add("active"); // 詳細メニュー表示

                setDetailMenu(targetTaskId);// 詳細メニューの値設定
                return;
            }

            // 削除ボタンが押されたら
            const deleteBtn = e.target.closest('#menu-delete-btn');
            if (deleteBtn){
                const deleteForm = document.getElementById('delete-form');

                // ハンドラーとIDを指定するURLクエリを追加
                deleteForm.action = `?handler=delete&id=${targetTaskId}`;

                // submit
                deleteForm.submit();
            }
            
            // 右クリックメニュー以外がクリックされたら
            if (!e.target.closest('#detail-menu')){
                overlay.classList.remove("active"); // 暗転解除
                detailMenu.classList.remove("active"); // 詳細メニュー解除
                return;
            }

        });

        // 2.詳細メニューの値設定
        const setDetailMenu = (id) => {
            
            const targetTaskId = document.getElementById("target-taskid");

            targetTaskId.textContent = id;




            const editBtn = document.getElementById('edit-btn');

            const currentHref = editBtn.getAttribute('href');

            console.log(currentHref);
            console.log('test');

            editBtn.href = currentHref+'/'+id; 
            
            
            const task = document.querySelector(`[data-id="${id}"]`);
            if(!task){
                console.error("task not found:", id);
                return;
            }
            
            // C#のPriorityListをJSで使える形(JSON)に変換して埋め込む
            const priorities = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PriorityList));
            
            // data-priorityidの値を取得
            // Numberで数値に変換
            const priId = Number(task.dataset.priorityid);
            
            // priorities配列から該当するデータを検索
            const priority = priorities.find(x => x.PriorityId === priId);
            
            // priority?.PriorityNamepriority   が undefined でもエラーにならない
            // ?? "不明"      PriorityName が無い or undefined の場合は "不明" を表示
            priorityId.textContent = priority?.PriorityName ?? "不明";


            //
            priorityId.classList.remove(
                "bg-danger","text-white",
                "bg-warning","text-dark",
                "bg-success",
            );

            switch (priId) {
                case 1:
                    priorityId.classList.add("bg-danger","text-white");
                    break;
                case 2:
                    priorityId.classList.add("bg-warning","text-dark");
                    break;
                case 3:
                    priorityId.classList.add("bg-success","text-white");
                    break;
            }
            // 値を表示
            taskName.textContent = task.dataset.taskname;


            deadlineAt.textContent = task.dataset.deadlineat;

            contentText.textContent = task.dataset.contenttext;

        };


        // 3.TOPへ戻る
        // A.表示切替
        document.addEventListener("scroll",()=>{
            const scrollY = window.scrollY || document.documentElement.scrollTop;

            document.getElementById("return-button").classList.toggle("active", scrollY > 100);
        }, { passive: true });
        // B.滑らか移動
        document.getElementById("scroll-to-top").addEventListener("click", (e) => {
            e.preventDefault();

            window.scrollTo({
                top: 0,
                behavior: "smooth"
            });
        });




    </script>
}


<!-- ヘッダーパーツ -->
@section AdditionalHeader {
    <!-- タスクリスト項目名 -->
    <div class="d-flex align-items-center">
        <!-- 作成ボタン -->
        <div class="col-2 col-md-1 d-inline-block">
            <a asp-page="/ToDoEditor" class="btn btn-primary">作成</a>
        </div>
        <!-- タスク名 -->
        <div class="col-7 col-md-6 d-inline-block fw-bold">タスク名</div>
        <!-- 期限 -->
        <div class="col-2 d-inline-block fw-bold">期限</div>
        <!-- フィルター -->
        <div class="col d-inline-block">
            <form method="get" class="input-group w-auto flex-nowrap">
                <label class="input-group-text d-none d-lg-inline-block">表示</label>
                <select asp-for="SelectedFilter" asp-items="@Model.FilterList" class="form-select" onchange="this.form.submit()"></select>
            </form>
        </div>
    </div>
}

<!-- アプリ本体 -->
<div class="container">
    @foreach (var item in Model.TaskList)
    {
        // 各種クラス名
        string taskColor = ""; // タスクの色
        string activeMark = ""; // ディレイ表示
        string activeBorder = ""; // 取り消し線表示
        // 完了しているか？
        bool isCompleted = @item.CompletedAt is not null;
        if (isCompleted)
        {
            // 完了色に変える
            taskColor = "completed-task";
            // ディレイを消す
            activeMark = "invisible";
            // 斜線を表示する
            activeBorder = "d-block";
        }
        else
        {
            // 斜線を消す
            activeBorder = "d-none";
            //PriorityIdを元にCSSクラス名（priority-1など）を作っている
            taskColor = $"priority-{item.PriorityId}";
            // 本日の日付を超えているか？超えていればディレイマークを付ける
            var isDelay = item.DeadlineAt.Date < DateTime.Today.Date;
            activeMark = isDelay ? "" : "invisible";
        }

        <!-- タスク1件 -->
        <div class="row">
            <div class="d-flex align-items-center shadow border rounded-3 py-2 mb-3 @taskColor"
                 data-id="@item.TaskId"
                 data-priorityid="@item.PriorityId"
                 data-taskname="@item.TaskName"
                 data-deadlineat="@item.DeadlineAt"
                 data-contenttext="@item.ContentText">
                <!-- チェックボタン -->
                <form method="post" asp-page-handler="Complete" asp-route-id="@item.TaskId" class="col-2 col-md-1 d-inline-block text-center">
                    <input type="hidden" asp-for="SelectedFilter" />
                    <input type="checkbox" checked="@isCompleted" onchange="this.form.submit()" click-without class="btn-complete" />
                </form>
                <!-- タスク名 -->
                <div class="col-6 col-md-5 fw-bold">@item.TaskName</div>
                <!-- 警告表示 -->
                <div class="col-1 d-inline-block text-end">
                    <span class="@activeMark" style="font-size:2.5rem; letter-spacing:0.5rem;">&#x26A0;&#xFE0F;</span>
                </div>
                <!-- 期限 -->
                <div class="col fw-bold">@item.DeadlineAt.ToString("yyyy/MM/dd")</div>
            </div>
        </div>

        <!-- 取り消し線（完了時） -->
        <span class="custom-strike position-relative align-baseline @activeBorder"></span>
    }  
</div>

<!-- 暗転オブジェクト -->
<div id="overlay" class="overlay"></div>

<!-- 右表示メニュー -->
<div id="detail-menu" class="detail-menu">

    <div id="target-taskid" data-taskid="target-taskid" hidden></div>

    <div class="row mb-3">
        <div class="border priority-box">
            優先度：<span id="priorityId" class="fw-bold"></span>
        </div>
    </div>

    <div class="row mb-3">
        <label class="form-label fw-bold">タスク名:</label>
            <div id="taskName" class="form-control"></div>
    </div>

    <div class="row mb-3">
        <label class="form-label fw-bold">期限:</label>
            <div id="deadlineAt" class="form-control"></div>
    </div>

    <div class="row mb-3">
        <label class="form-label fw-bold">詳細内容:</label>
            <div id="contentText" class="form-control"></div>
    </div>

    <div class="col-auto text-center d-flex gap-3">
        <!-- 更新ボタン -->
        <div>
            <!-- Bootstrapの改行防止クラス text-nowrapを追加 -->
            <a asp-page="/ToDoEditor" id="edit-btn" class="btn btn-primary text-nowrap">編集</a>
        </div>

        <!-- 完了切り替え -->
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="flexSwitchCheckDefault">オン/オフの切り替え</label>
        </div>


        <!-- 削除ボタン（ms-auto を追加して右寄せ） -->
        <form method="post" id="delete-form" class=" ms-auto">
            <button type="button" id="menu-delete-btn" class="btn btn-outline-danger text-nowrap">削除</button>
        </form>
    </div>


</div>

<!-- フロートボタン -->
<div id="return-button" class="return-button position-fixed" style="left:30px; bottom:15px; z-index: 1050;">
    <div class="">
        <button id="scroll-to-top" class="btn btn-primary">TOPに戻る</button>
    </div>
</div>

